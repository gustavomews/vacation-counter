{
  "name": "vacation-counter",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build:ts": "pnpm exec tsc -p tsconfig.json",
    "copy:assets": "node scripts/copy-assets.mjs",
    "build": "pnpm run clean && pnpm run build:ts && pnpm run copy:assets",
    "watch": "pnpm exec tsc -w -p tsconfig.json",
    "serve": "node scripts/serve-dist.mjs",
    "start": "pnpm run build && pnpm run serve"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
